rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt']) && data.keys().size() == 3
          && data.email is string && data.email.size() <= 100
          && data.role is string && (data.role == 'user' || data.role == 'admin')
          && data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'content', 'createdAt']) && data.keys().size() == 4
          && data.name is string && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.content is string && data.content.size() <= 1000
          && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId 
                    && isValidUser(incoming()) 
                    && incoming().email == request.auth.token.email
                    && incoming().role == 'user' 
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin())
                    && isValidUser(incoming())
                    && incoming().createdAt == existing().createdAt
                    && (isAdmin() || incoming().role == existing().role)
                    && (incoming().diff(existing()).affectedKeys().hasOnly(['email']) || incoming().diff(existing()).affectedKeys().size() == 0);
      allow delete: if isAdmin() && isValidId(userId);
    }

    match /messages/{messageId} {
      allow get, list: if isAdmin();
      allow create: if isValidId(messageId) && isValidMessage(incoming()) && incoming().createdAt == request.time;
      allow update, delete: if isAdmin() && isValidId(messageId);
    }
  }
}
