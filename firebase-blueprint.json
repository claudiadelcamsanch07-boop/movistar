{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "maxLength": 100
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "message": {
      "title": "Message",
      "description": "Contact form message.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 100
        },
        "email": {
          "type": "string",
          "maxLength": 100
        },
        "content": {
          "type": "string",
          "maxLength": 1000
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "email", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/user"
      },
      "description": "User profiles."
    },
    "messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/message"
      },
      "description": "Messages submitted via the contact form."
    }
  }
}
